---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a"> & { textWhite?: boolean };

const { href, textWhite = false, ...props } = Astro.props;

const { pathname } = Astro.url;
const isActive = href === pathname || href === pathname.replace(/\/$/, "");
---

<a
  rel="prefetch"
  data-astro-prefetch
  href={href}
  class:list={["mx-2", textWhite ? "text-white!" : "text-text-link! dark:text-white!", { active: isActive }]}
  {...props}><slot /></a
>
